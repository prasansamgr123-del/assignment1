<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Professionals</title>
    <style>
      body {
        font-family: sans-serif;
        max-width: 700px;
        margin: 40px auto;
        padding: 0 16px;
      }
      h1 {
        text-align: center;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
      }
      th,
      td {
        border: 1px solid #ccc;
        padding: 8px 12px;
        text-align: left;
      }
      th {
        background: #f4f4f4;
      }
    </style>
  </head>
  <body>
    <h1>Professionals</h1>

    <!-- The angle-percent-equals tag below PRINTS a value into the HTML. -->
    <p>Total: <%= professionals.length %></p>

    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
        </tr>
      </thead>
      <tbody>
        <!-- The angle-percent tag below RUNS JavaScript (a loop) but prints nothing itself. -->
        <% professionals.forEach((professional, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= professional.name %></td>
          <td><%= professional.category %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </body>
</html>
